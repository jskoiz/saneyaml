---
apiVersion: apiextensions.k8s.io/v1
kind: CustomResourceDefinition
metad`ta:
  name: widgets.example.com
spec:
  group: example.com
  scope: Namespaced
  names:
    plural: widgets
    singular: widget
    kind: Widget
    shortNames: [wdg]
  versions:
    - name: v1alpha1
      served: true
   
        openAPIV3Schema:
          type: object
          required: [spec]
          properties:
            spec:
              type: object
              required: [image, replicas]
              properties:
                image:
                  type: string
                replicas:
                  type: integer
                  minimum: 1
                  default: 1
                mode:
                  type: string
                  enum: [dev, prod]
                config:
                  type: object
                  x-kubernetes-preserve-unknown-fields: true
                  additionalProperties:
                    type: string
                rules:
                  type: array
                  x-kubernetes-list-type: map
                  x-kubernetes-list-map-keys: [name]
                  items:
                    type: object
                    required: [name]
                    properties:
                      name:
                        type: string
                      enabled:
                        type: boolean
                        default: true
---
apiVersion: example.com/v1alpha1
kind: Widget
metadata:
  name: demo-widget
  namespace: default
spec:
  image: ghcr.io/example/widget:1.0
  replicas: 2
  mode: prod
  config:
    FEATURE_FLAG: "true"
    LOG_LEVEL: info
  rules:
    - name: cache
      enabled: true
    - name: search
      enabled: false
