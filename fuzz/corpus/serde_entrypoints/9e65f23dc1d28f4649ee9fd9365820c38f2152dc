version: "3.9"
services:
  web:
    image: ghcr.io/example/web:1.2.3
    environment:
      - RUST_LOG=info
      - FEATURE_FLAG=true
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://localhost:8080/health || exit 1"]
    volumes:
      - type: bind
        source: ./config
     .   target: /etc/yaml-demo
